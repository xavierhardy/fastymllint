{
  "pipeline": {
    "name": "MegaLinter Rust CI Pipeline",
    "description": "Automated testing, linting, formatting and building for MegaLinter Rust project",
    "steps": [
      {
        "id": "format",
        "name": "Code Formatting",
        "description": "Format code with cargo fmt",
        "commands": [
          "cargo fmt --all"
        ]
      },
      {
        "id": "lint",
        "name": "Code Linting",
        "description": "Lint code with cargo clippy",
        "commands": [
          "cargo clippy -- -D warnings"
        ]
      },
      {
        "id": "test",
        "name": "Unit Tests",
        "description": "Run test suite",
        "commands": [
          "cargo test --all"
        ]
      },
      {
        "id": "precommit",
        "name": "Pre-commit Build",
        "description": "Build release binary",
        "commands": [
          "cargo build --release"
        ]
      }
    ]
  }
}